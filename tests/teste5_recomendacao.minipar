# Programa de Teste 5: Sistema de Recomendacao E-commerce (Redes Neurais)
func relu(x) {
    if (x > 0.0) { return x; }
    return 0.0;
}

func sigmoid(x) {
    return 1.0 / (1.0 + exp(0.0 - x));
}

seq {
    print("=== Sistema de Recomendacao E-commerce ===");
    
    # Historico codificado do usuario (1 = comprou, 0 = nao comprou)
    # Produtos catalogados: ["Smartphone", "Jeans", "Micro-ondas", "Ficcao"]
    var historico = [1.0, 1.0, 0.0, 0.0]; 
    
    # Pesos e bias simplificados para a rede neural
    var pesos_ocultos = [0.2, 0.0 - 0.5, 0.8, 0.1];
    var bias_oculto = 0.5;
    
    var pesos_saida = [0.5, 0.5, 0.5, 0.5];
    var bias_saida = 0.5;
    
    var i = 0;
    var size = historico.size();
    
    print("Produtos recomendados para voce (analisando indices de produtos nao comprados):");
    
    while (i < size) {
        var input_val = historico[i];
        
        # Propagacao (Forward Propagation) simples por produto
        var z1 = (input_val * pesos_ocultos[i]) + bias_oculto;
        var a1 = relu(z1);
        
        var z2 = (a1 * pesos_saida[i]) + bias_saida;
        var prob = sigmoid(z2);
        
        # Se a probabilidade for alta e o usuario ainda nao comprou o produto (0)
        if (prob > 0.5) {
            if (input_val == 0) {
                print("-> Recomendacao de produto no Indice [", i, "] com prob: ", prob);
            }
        }
        i = i + 1;
    }
}