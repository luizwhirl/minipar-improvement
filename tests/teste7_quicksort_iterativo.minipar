# Programa de Teste 7: Quicksort Iterativo
seq {
    var arr = [33, 12, 98, 5, 61];
    var start_stack = [0];
    var end_stack = [4];
    
    print("Array original: ", arr);

    while (start_stack.size() > 0) {
        var start = start_stack.pop();
        var end = end_stack.pop();
        
        if (start < end) {
            var pivot = arr[end];
            var i = start - 1;
            var j = start;
            
            while (j < end) {
                if (arr[j] <= pivot) {
                    i = i + 1;
                    var temp = arr[i];
                    arr[i] = arr[j];
                    arr[j] = temp;
                }
                j = j + 1;
            }
            var temp2 = arr[i + 1];
            arr[i + 1] = arr[end];
            arr[end] = temp2;
            
            var pi = i + 1;
            
            start_stack.append(start);
            end_stack.append(pi - 1);
            
            start_stack.append(pi + 1);
            end_stack.append(end);
        }
    }
    print("Array ordenado: ", arr);
}