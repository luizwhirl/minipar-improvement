# Programa de Teste 6: Ordenacao com Quicksort Recursivo e POO
class Quicksort {
    var array = [0];

    # Metodo auxiliar para fazer o particionamento do vetor in-place
    func partition(low, high) {
        var pivot = this.array[high];
        var i = low - 1;
        var j = low;

        while (j < high) {
            if (this.array[j] <= pivot) {
                i = i + 1;
                var temp = this.array[i];
                this.array[i] = this.array[j];
                this.array[j] = temp;
            }
            j = j + 1;
        }
        var temp2 = this.array[i + 1];
        this.array[i + 1] = this.array[high];
        this.array[high] = temp2;

        return i + 1;
    }

    # Metodo de recursao
    func _quicksort(low, high) {
        if (low < high) {
            var pi = this.partition(low, high);
            this._quicksort(low, pi - 1);
            this._quicksort(pi + 1, high);
        }
        return 0;
    }

    # Metodo principal de acionamento do algoritmo
    func ordenar() {
        var n = this.array.size();
        this._quicksort(0, n - 1);
        return 0;
    }
}

class InterfaceOrdenacao {
    func iniciar() {
        print("==== Ordenacao com Quicksort ====");
        var qs = new Quicksort();
        
        # Simulando o array inserido pelo usuario como no Teste 6
        qs.array = [10, -3, -40, 80, 70, -100];
        print("Vetor original: ", qs.array);
        
        qs.ordenar();
        print("Vetor ordenado: ", qs.array);
    }
}

seq {
    # Instanciamento e chamada encadeada respeitando os moldes de POO
    var interface_ord = new InterfaceOrdenacao();
    interface_ord.iniciar();
}