# Programa de Teste 1: Calculadora Cliente/Servidor
var calculadora = c_channel("127.0.0.1", 8080);

seq {
    par {
        # Servidor (Computador 2)
        seq {
            var req = receive(calculadora);
            print("Servidor recebeu a operacao: ", req);
            # O servidor simula o processamento do calculo "10 + 5"
            send(calculadora, "Resultado da operacao = 15");
        }
        # Cliente (Computador 1)
        seq {
            print("=== Calculadora Aritmetica ===");
            print("Opcoes: +, -, *, /");
            print("Enviando solicitacao (10 + 5)...");
            send(calculadora, "10 + 5");
            var res = receive(calculadora);
            print("Cliente recebeu: ", res);
        }
    }
}