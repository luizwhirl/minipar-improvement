# Para laboratorio, troque os IPs 127.0.0.1 pelos IP:porta dos tres PCs:
# PC1 QuickSort, PC2 multiplicacao de matrizes, PC3 fatorial.
seq {
    var pc1 = c_channel("127.0.0.1", 5201);
    var pc2 = c_channel("127.0.0.1", 5202);
    var pc3 = c_channel("127.0.0.1", 5203);
    par {
        seq {
            send(pc1, "PC1 QuickSort: [33,12,98,5,61] -> [5,12,33,61,98]");
        }
        seq {
            send(pc2, "PC2 Matrizes: [[1,2],[3,4]] x [[5,6],[7,8]] -> [[19,22],[43,50]]");
        }
        seq {
            send(pc3, "PC3 Fatorial: 5! = 120");
        }
    }
}
