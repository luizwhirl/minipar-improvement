# Programa de Teste 2: Paralelismo Fatorial e Fibonacci
func fatorial(n) {
    if (n <= 1) { return 1; }
    return n * fatorial(n - 1);
}

func fibonacci(n) {
    if (n <= 1) { return n; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

seq {
    par {
        seq {
            print("Thread 1 (Fatorial) iniciada...");
            var fat = fatorial(5);
            print("Resultado Fatorial de 5: ", fat);
        }
        seq {
            print("Thread 2 (Fibonacci) iniciada...");
            var fib = fibonacci(10);
            print("Resultado Fibonacci de 10: ", fib);
        }
    }
}