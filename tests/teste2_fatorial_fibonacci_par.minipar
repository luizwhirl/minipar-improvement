par {
    seq {
        var n = 5;
        var fat = 1;
        var i = 1;
        while (i <= n) {
            fat = fat * i;
            i = i + 1;
        }
        print("Fatorial de 5:", fat);
    }
    seq {
        var limite = 8;
        var a = 0;
        var b = 1;
        var i = 0;
        print("Fibonacci:");
        while (i < limite) {
            print(a);
            var prox = a + b;
            a = b;
            b = prox;
            i = i + 1;
        }
    }
}
