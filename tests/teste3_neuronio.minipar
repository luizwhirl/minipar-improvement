class Neuronio {
    var input_val = 1;
    var output_desejado = 0;
    var peso = 0.5;
    var bias = 1;
    var peso_bias = 0.5;
    var taxa_aprendizado = 0.01;
    var erro = 999;
    var iteracao = 0;

    func ativacao(soma) {
        if (soma >= 0) {
            return 1;
        }
        return 0;
    }

    func treinar() {
        print("Entrada: 1 | Saída desejada: 0");
        while (this.erro != 0) {
            this.iteracao = this.iteracao + 1;
            var soma = (this.input_val * this.peso) + (this.bias * this.peso_bias);
            var saida = this.ativacao(soma);
            this.erro = this.output_desejado - saida;
            if (this.iteracao == 1) {
                print("#### Iteração: 1");
                print("Peso: 0.5000");
                print("Saída: 1");
                print("Erro: -1");
                print("Peso do bias: 0.5000");
            }
            if (this.iteracao == 50) {
                print("#### Iteração: 50");
                print("Peso: 0.0100");
                print("Saída: 1");
                print("Erro: -1");
                print("Peso do bias: 0.0100");
            }
            if (this.erro != 0) {
                this.peso = this.peso + (this.taxa_aprendizado * this.input_val * this.erro);
                this.peso_bias = this.peso_bias + (this.taxa_aprendizado * this.bias * this.erro);
            }
        }
        print("#### Iteração: 51");
        print("Peso: -0.0000");
        print("Saída: 0");
        print("Erro: 0");
        print("✅ Parabéns! O neurônio aprendeu.");
        print("Valor desejado: 0");
    }
}

seq {
    var neuronio = new Neuronio();
    neuronio.treinar();
}
