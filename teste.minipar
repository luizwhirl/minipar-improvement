seq {
    var contador = 5;
    print("Iniciando laco de repeticao!");

    while (contador > 0) {
        if (contador == 3) {
            print("Chegamos na metade! Contador:", contador);
        } else {
            print("Rodando... Contador:", contador);
        }
        contador = contador - 1;
    }
    
    print("Laco encerrado com sucesso.");
}